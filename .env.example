# PersonalMind 环境变量配置示例
# 复制此文件为 .env 并填入你的配置

# ============== OpenAI API ==============
# 必需：OpenAI API Key
OPENAI_API_KEY=sk-your-api-key-here

# 可选：使用的模型（默认 gpt-3.5-turbo）
OPENAI_MODEL=gpt-3.5-turbo

# 可选：生成温度 0-1，越低越确定性（默认 0.7）
OPENAI_TEMPERATURE=0.7

# 可选：最大 token 数（默认 2000）
OPENAI_MAX_TOKENS=2000

# ============== 工具配置 ==============
# 是否启用联网搜索（默认 true）
ENABLE_WEB_SEARCH=true

# 是否启用计算器（默认 true）
ENABLE_CALCULATOR=true

# 是否启用代码执行器（默认 false，建议保持关闭）
ENABLE_CODE_EXECUTOR=false

# ============== Web UI 配置 ==============
# Web UI 端口（默认 7860）
WEB_UI_PORT=7860

# 是否创建公开分享链接（默认 false）
WEB_UI_SHARE=false

# ============== 数据存储 ==============
# 数据目录（默认 ./data）
DATA_DIR=./data

# 向量数据库持久化目录
CHROMA_PERSIST_DIR=./data/chromadb
